# =============================================================================
# Secrets & credentials  — never commit these
# =============================================================================
.env
*.key
*.pem
*.p12
*.pfx
secrets/
credentials/

# =============================================================================
# Runtime data  — machine-specific, potentially large, contains financial data
# =============================================================================

# SQLite database and WAL/SHM files
data/*.db
data/*.db-wal
data/*.db-shm
data/*.sqlite
data/*.sqlite-wal
data/*.sqlite-shm

# Keep the data directory itself (needed for Docker volume mount)
!data/.gitkeep

# Log files
logs/*.log
logs/*.log.*
logs/*.gz

# Keep the logs directory itself
!logs/.gitkeep

# =============================================================================
# Python
# =============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
*.pyd

# Distribution / packaging
.Python
build/
dist/
develop-eggs/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual environments
venv/
venv_*/
env/
ENV/
.venv/
.env/
venv.bak/

# pip
pip-log.txt
pip-delete-this-directory.txt

# =============================================================================
# Testing & coverage
# =============================================================================
.pytest_cache/
.coverage
.coverage.*
coverage.xml
*.cover
*.py,cover
htmlcov/
.tox/
.nox/
nosetests.xml
test-results/

# =============================================================================
# Type checkers & linters
# =============================================================================
.mypy_cache/
.dmypy.json
dmypy.json
.ruff_cache/
.pytype/

# =============================================================================
# Jupyter (used for backtesting analysis)
# =============================================================================
.ipynb_checkpoints/
*.ipynb

# =============================================================================
# IDEs & editors
# =============================================================================

# VS Code
.vscode/
*.code-workspace

# JetBrains (PyCharm, IntelliJ)
.idea/
*.iml
*.iws
*.ipr

# Vim / Neovim
*.swp
*.swo
*~
.netrwhist

# Emacs
\#*\#
/.emacs.desktop
/.emacs.desktop.lock
*.elc
auto-save-list
tramp
.\#*

# Sublime Text
*.sublime-project
*.sublime-workspace

# =============================================================================
# Operating system
# =============================================================================

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes
.fseventsd
.TemporaryItems

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
.directory
.Trash-*

